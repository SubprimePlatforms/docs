					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"applicant@example.com\",\n    \"first_name\": \"Jane\",\n    \"last_name\": \"Smith\",\n    \"phone\": \"+15192223333\",\n    \"send_email_invite\": false,\n    \"send_phone_invite\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/sessions",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"]
						},
						"description": "Creates a session without sending any email or SMS invites. Useful for programmatic flows where you handle the invite delivery yourself."
					}
				},
				{
					"name": "List Sessions (My Sent)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/sessions?limit=50",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"],
							"query": [
								{
									"key": "limit",
									"value": "50",
									"description": "Number of results (1-500, default 50)"
								},
								{
									"key": "next_token",
									"value": "",
									"description": "Pagination token from previous response",
									"disabled": true
								},
								{
									"key": "start_date",
									"value": "2024-01-01T00:00:00Z",
									"description": "ISO 8601 start date filter",
									"disabled": true
								},
								{
									"key": "end_date",
									"value": "2025-12-31T23:59:59Z",
									"description": "ISO 8601 end date filter",
									"disabled": true
								}
							]
						},
						"description": "Lists sessions sent by the authenticated API key user (default mode). Supports pagination via `next_token` and date range filtering."
					}
				},
				{
					"name": "List Sessions (By Organization)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/sessions?by_organization=true&limit=50",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"],
							"query": [
								{
									"key": "by_organization",
									"value": "true",
									"description": "List all sessions across the organization"
								},
								{
									"key": "limit",
									"value": "50"
								},
								{
									"key": "next_token",
									"value": "",
									"disabled": true
								},
								{
									"key": "start_date",
									"value": "",
									"disabled": true
								},
								{
									"key": "end_date",
									"value": "",
									"disabled": true
								}
							]
						},
						"description": "Lists all sessions across the entire organization, regardless of which user sent them."
					}
				},
				{
					"name": "List Sessions (By External ID)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/sessions?external_id={{external_id}}&limit=50",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"],
							"query": [
								{
									"key": "external_id",
									"value": "{{external_id}}",
									"description": "Your external reference ID"
								},
								{
									"key": "limit",
									"value": "50"
								},
								{
									"key": "next_token",
									"value": "",
									"disabled": true
								},
								{
									"key": "start_date",
									"value": "",
									"disabled": true
								},
								{
									"key": "end_date",
									"value": "",
									"disabled": true
								}
							]
						},
						"description": "Lists sessions matching a specific external ID you provided when creating the session."
					}
				},
				{
					"name": "List Sessions (By Workflow ID)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/sessions?workflow_id={{workflow_id}}&limit=50",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"],
							"query": [
								{
									"key": "workflow_id",
									"value": "{{workflow_id}}",
									"description": "Filter by workflow ID"
								},
								{
									"key": "limit",
									"value": "50"
								},
								{
									"key": "next_token",
									"value": "",
									"disabled": true
								},
								{
									"key": "start_date",
									"value": "",
									"disabled": true
								},
								{
									"key": "end_date",
									"value": "",
									"disabled": true
								}
							]
						},
						"description": "Lists sessions created under a specific workflow."
					}
				},
				{
					"name": "Get Session by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/sessions/{{session_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions", "{{session_id}}"]
						},
						"description": "Fetches a single session by its ID. Returns the full session record with `analysis_data`, `uploads` booleans, and pre-signed S3 `resource_links` for any uploaded documents/images (valid for 5 minutes)."
					}
				},
				{
					"name": "Update Session Status (Verify)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"new_status\": \"VERIFIED\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/sessions/{{session_id}}/update-status",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions", "{{session_id}}", "update-status"]
						},
						"description": "Marks a session as VERIFIED. Only allowed values for `new_status` are `VERIFIED` and `REJECTED`."
					}
				},
