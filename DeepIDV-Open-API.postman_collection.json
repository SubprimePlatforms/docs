						},
						"description": "Marks a session as REJECTED."
					}
				}
			]
		},
		{
			"name": "Workflows",
			"description": "Workflow template endpoints. Workflows define the steps an applicant goes through in a session.",
			"item": [
				{
					"name": "List Workflows",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.workflows && json.workflows.length > 0) {",
									"        pm.collectionVariables.set('workflow_id', json.workflows[0].id);",
									"        console.log('Saved workflow_id: ' + json.workflows[0].id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/workflows",
							"host": ["{{base_url}}"],
							"path": ["v1", "workflows"]
						},
						"description": "Lists all workflows for your organization. Returns `id`, `name`, `status`, `steps` (array of step IDs like ID_VERIFICATION, FACE_LIVENESS, etc.), and `created_at` for each workflow.\n\nAuto-saves the first workflow's ID to the `workflow_id` collection variable."
					}
				},
				{
					"name": "Create Workflow",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    if (json.workflow && json.workflow.id) {",
									"        pm.collectionVariables.set('workflow_id', json.workflow.id);",
									"        console.log('Saved workflow_id: ' + json.workflow.id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"KYC Verification\",\n    \"steps\": [\n        {\n            \"id\": \"ID_VERIFICATION\",\n            \"config\": {\n                \"minimum_age\": 18,\n                \"expiry_date_years\": 2\n            }\n        },\n        {\n            \"id\": \"FACE_LIVENESS\",\n            \"config\": {\n                \"confidence_threshold\": 70\n            }\n        },\n        {\n            \"id\": \"PEP_SANCTIONS\"\n        },\n        {\n            \"id\": \"ADVERSE_MEDIA\"\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/workflows",
							"host": ["{{base_url}}"],
							"path": ["v1", "workflows"]
						},
						"description": "Creates a new workflow for your organization.\n\n**Required fields:** name, steps (array with at least 1 step)\n\n**Available step IDs:** ID_VERIFICATION, FACE_LIVENESS, AGE_ESTIMATION, PEP_SANCTIONS, ADVERSE_MEDIA\n\n**Optional config per step:**\n- ID_VERIFICATION: minimum_age, maximum_age, expiry_date_years, require_secondary_id, require_tertiary_id, face_front_photo_only, require_front_only\n- FACE_LIVENESS: confidence_threshold (1-100, default 70)\n- AGE_ESTIMATION: minimum_age (1-100, default 18)\n- PEP_SANCTIONS / ADVERSE_MEDIA: no config needed\n\nAuto-saves the created workflow's ID to the `workflow_id` collection variable."
					}
				},
				{
					"name": "Create Workflow (Minimal)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    if (json.workflow && json.workflow.id) {",
									"        pm.collectionVariables.set('workflow_id', json.workflow.id);",
									"        console.log('Saved workflow_id: ' + json.workflow.id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Basic Liveness Check\",\n    \"steps\": [\n        {\n            \"id\": \"FACE_LIVENESS\"\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/workflows",
							"host": ["{{base_url}}"],
							"path": ["v1", "workflows"]
						},
						"description": "Creates a minimal workflow with a single step using all default configuration. Demonstrates that config is optional on every step."
					}
				},
				{
					"name": "Get Workflow by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/workflows/{{workflow_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "workflows", "{{workflow_id}}"]
						},
						"description": "Fetches a single workflow by ID with its full step configuration. Steps can include: id-verification, face-liveness, age-estimation, pep-sanctions, bank-statement-upload, custom-prompt, document-upload, custom-form, title-search, adverse-media."
					}
				}
			]
		},
