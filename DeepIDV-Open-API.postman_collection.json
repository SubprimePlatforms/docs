{
	"info": {
		"name": "DeepIDV Open API",
		"description": "Comprehensive collection for the DeepIDV Open API. Set the `api_key` variable in the collection variables before running requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "x-api-key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "{{api_key}}",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://api.deepidv.com",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "workflow_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "bank_statement_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "external_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Returns 200 OK if the API server is running. No authentication required."
					}
				}
			]
		},
		{
			"name": "Sessions (IDV)",
			"description": "Identity verification session endpoints. Mounted at `/v1/sessions` (and legacy `/v1/idv`).",
			"item": [
				{
					"name": "Create Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.idv_id) {",
									"        pm.collectionVariables.set('session_id', json.idv_id);",
									"        console.log('Saved session_id: ' + json.idv_id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"applicant@example.com\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone\": \"+15192223333\",\n    \"external_id\": \"your-internal-ref-123\",\n    \"send_email_invite\": true,\n    \"send_phone_invite\": true,\n    \"workflow_id\": \"\",\n    \"redirect_url\": \"https://yourapp.com/verify-callback\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/sessions",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"]
						},
						"description": "Creates a new IDV session and sends an email/SMS invite to the applicant.\n\n**Required fields:** email, first_name, last_name, phone (E.164 format e.g. +15192223333)\n\n**Optional fields:** external_id, send_email_invite (default true), send_phone_invite (default true), workflow_id, redirect_url\n\n- `redirect_url`: HTTPS URL to redirect the applicant to after the session ends. Query params `session_id`, `status`, and `reason` are appended automatically.\n\nAccepts both camelCase and snake_case field names.\n\nAuto-saves the returned `idv_id` to the `session_id` collection variable."
					}
				},
				{
					"name": "Create Session (with Workflow)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.idv_id) {",
									"        pm.collectionVariables.set('session_id', json.idv_id);",
									"        console.log('Saved session_id: ' + json.idv_id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"applicant@example.com\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone\": \"+15192223333\",\n    \"external_id\": \"your-internal-ref-456\",\n    \"send_email_invite\": true,\n    \"send_phone_invite\": false,\n    \"workflow_id\": \"{{workflow_id}}\",\n    \"redirect_url\": \"https://yourapp.com/verify-callback\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/sessions",
							"host": ["{{base_url}}"],
							"path": ["v1", "sessions"]
						},
						"description": "Creates a session tied to a specific workflow. Set the `workflow_id` collection variable first (e.g. from the List Workflows request)."
					}
				},
