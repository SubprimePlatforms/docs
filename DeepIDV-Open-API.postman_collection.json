					"name": "Create Session (No Invites)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.idv_id) {",
									"        pm.collectionVariables.set('session_id', json.idv_id);",
									"        console.log('Saved session_id: ' + json.idv_id);",
									"    }",
									"}"
								]
							}
						}
